@page "/skill"

<PageTitle>Skill</PageTitle>

<div class="skills-container">
    <h2>Skills</h2>
    
    <div class="skills-grid">
        <div class="skill-card">
            <div class="skill-header">HTML</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 65%;"></div>
                </div>
                <div class="progress-percentage">65%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">CSS</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 60%;"></div>
                </div>
                <div class="progress-percentage">60%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">JavaScript</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 30%;"></div>
                </div>
                <div class="progress-percentage">30%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">JAVA</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 40%;"></div>
                </div>
                <div class="progress-percentage">40%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">.NET</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 15%;"></div>
                </div>
                <div class="progress-percentage">15%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">Python</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 10%;"></div>
                </div>
                <div class="progress-percentage">10%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">SQL</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 15%;"></div>
                </div>
                <div class="progress-percentage">15%</div>
            </div>
        </div>

        <div class="skill-card">
            <div class="skill-header">C</div>
            <div class="skill-body">
                <div class="progress-bar">
                    <div class="progress-fill" style="width: 70%;"></div>
                </div>
                <div class="progress-percentage">70%</div>
            </div>
        </div>
    </div>
</div>